# === Pi Workstation — Proxy via Tailscale mesh (100.64.0.1) ===
# REX: DNS studio/cut/oc.ewutelo.cloud → Seko-VPN (87.106.30.160)
#      Caddy TLS termine ici, puis proxy HTTP vers le Pi via Tailscale
#      VPN-only : Tailscale IPs uniquement (caddy_vpn_enforce=true recommandé)

# ComfyUI (génération d'images AI)
{{ domain_comfyui }} {
    import vpn_only
    import vpn_error_page

    reverse_proxy {{ pi_tailscale_ip }}:8188 {
        transport http {
            dial_timeout 10s
            response_header_timeout 120s
        }
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        -Server
    }
}

